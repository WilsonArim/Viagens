
# ────────────────────────────────────────────
# DATABASE (Neon – https://neon.tech)
# ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-west-1.aws.neon.tech/detetive_viagens?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.eu-west-1.aws.neon.tech/detetive_viagens?sslmode=require"

# ────────────────────────────────────────────
# GOOGLE OAUTH (https://console.cloud.google.com)
# ────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ────────────────────────────────────────────
# NEXTAUTH (gera um segredo com: openssl rand -base64 32)
# ────────────────────────────────────────────
NEXTAUTH_SECRET="your_nextauth_secret"
NEXTAUTH_URL="https://teu-dominio.vercel.app"

# ────────────────────────────────────────────
# AI APIs
# ────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key"
XAI_API_KEY="your_xai_api_key"

# ────────────────────────────────────────────
# GOOGLE PLACES (https://console.cloud.google.com)
# ────────────────────────────────────────────
GOOGLE_PLACES_API_KEY="your_google_places_api_key"

# ────────────────────────────────────────────
# nif.pt API
# ────────────────────────────────────────────
NIFPT_API_KEY="your_nifpt_api_key"

# ────────────────────────────────────────────
# NOMINATIM (OSM geocoding)
# ────────────────────────────────────────────
NOMINATIM_USER_AGENT="amigo-de-viagens/1.0 (contact: teu-email@dominio.com)"

# ────────────────────────────────────────────
# SENTRY (optional — https://sentry.io)
# ────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ────────────────────────────────────────────
# REDIS (optional — https://upstash.com)
# ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────
LOG_LEVEL="debug"
