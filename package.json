{
  "name": "amigo-de-viagens-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:deploy": "prisma migrate deploy",
    "nifpt:sync": "npx tsx --env-file=.env scripts/nifpt-sync-worker.ts",
    "nifpt:sync:bg": "npx tsx --env-file=.env scripts/nifpt-sync-worker.ts >> logs/nifpt-sync.log 2>&1 &",
    "google:seed": "npx tsx --env-file=.env prisma/seed-google-places.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^10.43.0",
    "@types/leaflet": "^1.9.21",
    "framer-motion": "^12.34.4",
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "openai": "^6.25.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
